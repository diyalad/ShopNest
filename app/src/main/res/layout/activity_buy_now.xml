<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Toolbar with Back Button and Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/baseline_arrow_back_ios_new_24"
            android:contentDescription="Back"
            android:padding="8dp" />

        <!-- Title: Order Summary -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order Summary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/deep_blue"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Progress Indicator -->
    <!-- Progress Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/step1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:background="@drawable/circle_background"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:padding="8dp"/>

        <View
            android:id="@+id/line1"
            android:layout_width="50dp"
            android:layout_height="2dp"
            android:background="@color/gray_light"
            android:layout_marginHorizontal="8dp"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/step2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2"
            android:background="@drawable/circle_background_gray"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:padding="8dp"/>

        <View
            android:id="@+id/line2"
            android:layout_width="50dp"
            android:layout_height="2dp"
            android:background="@color/gray_light"
            android:layout_marginHorizontal="8dp"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/step3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3"
            android:background="@drawable/circle_background_gray"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- NestedScrollView for Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Address Section in a Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="3dp"
                android:layout_marginBottom="16dp">

                <!-- Deliver to: and Change Button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <!-- Deliver to: -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deliver to:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="start|top">

                        <Button
                            android:id="@+id/changeAddressButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="158dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/button_ripple"
                            android:padding="8dp"
                            android:text="Change"
                            android:textColor="@color/deep_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Delivery Address -->
                <TextView
                    android:id="@+id/deliveryAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lad Harishbhai K HOME\n592, Maliyadhara Kumbharvad, Amba Matana Mandir ni same, Chikhil 396521\n9879016404"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>


            <!-- Product Details Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Details"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingBottom="8dp"/>

            <!-- Card Layout for Product Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="3dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/productImage"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/toy1"
                    android:scaleType="centerCrop"
                    android:background="@color/gray_light"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:id="@+id/productName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Varanga Women Kurta Pant Att..."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>

                    <TextView
                        android:id="@+id/productSize"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Size: M"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:paddingTop="4dp"/>

                    <TextView
                        android:id="@+id/productRating"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="★★★★★ 3.7 · (173)"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:paddingTop="4dp"/>

                    <TextView
                        android:id="@+id/productPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="₹5,599"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:paddingTop="4dp"/>

                    <!-- Quantity Selector -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp">

                        <!-- Minus Button -->
                        <Button
                            android:id="@+id/minusButton"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="-"
                            android:layout_gravity="center"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            android:background="@drawable/button_ripple"
                            android:padding="4dp"/>

                        <!-- Quantity TextView -->
                        <TextView
                            android:id="@+id/quantityTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textSize="16sp"
                            android:paddingHorizontal="16dp"
                            android:gravity="center"/>

                        <!-- Plus Button -->
                        <Button
                            android:id="@+id/plusButton"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:text="+"
                            android:textColor="@color/black"
                            android:textSize="18sp"
                            android:layout_gravity="center"
                            android:background="@drawable/button_ripple"
                            android:padding="4dp"/>
                    </LinearLayout>

                    <!-- Delivery Details Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="16dp">

                        <!-- Delivery Details Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivery Details"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:paddingEnd="8dp"/>

                        <!-- Delivery Date -->
                        <TextView
                            android:id="@+id/deliveryInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/delivery_date"
                            android:textSize="10sp"
                            android:textColor="@color/black"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <!-- Open Box Delivery Section in a CardView -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title with Emoji -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📦 Rest assured with Open Box Delivery"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:paddingBottom="8dp"/>

                    <!-- Grey Line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gray_light"
                        android:layout_marginBottom="8dp"/>

                    <!-- Description -->
                    <TextView
                        android:id="@+id/openBoxDeliveryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Delivery agent will open the package so you can check for correct product, damage or missing items. Share OTP to accept the delivery. Why?"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:paddingBottom="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Price Details Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Price Details"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingBottom="8dp"/>

            <!-- Card Layout for Price Details -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="3dp"
                android:paddingBottom="16dp">

                <!-- Price (1 item) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Price (1 item)"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"/>


                </LinearLayout>

                <!-- Discount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/priceDetails"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Discount"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"/>

                    <TextView
                        android:id="@+id/discountDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-₹4,661"
                        android:textSize="14sp"
                        android:textColor="@color/green"/>
                </LinearLayout>

                <!-- Platform Fee -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Platform Fee ⏱"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹3"
                        android:textSize="14sp"
                        android:textColor="@color/black"/>
                </LinearLayout>

                <!-- Delivery Charges -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Delivery Charges"
                        android:textSize="14sp"
                        android:textColor="@color/gray_dark"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FREE Delivery"
                        android:textSize="14sp"
                        android:textColor="@color/green"/>
                </LinearLayout>

                <!-- Total Amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/totalAmount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Amount"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Savings Text -->
            <TextView
                android:id="@+id/savingsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You'll save ₹4,658 on this order!"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="@color/green"
                android:background="@color/light_green"
                android:padding="8dp"
                android:paddingBottom="8dp"/>

            <!-- Terms and Conditions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="By continuing with the order, you confirm that you are above 18 years of age, and you agree to the Flipkart's Terms of Use and Privacy Policy."
                android:textSize="12sp"
                android:textColor="#7A747478"
                android:paddingBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Proceed to Payment Button -->
    <Button
        android:id="@+id/proceedToPaymentButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proceed to Payment"
        android:backgroundTint="@color/deep_blue"
        android:textColor="@color/white"
        android:padding="16dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:drawablePadding="8dp"/>
</LinearLayout>