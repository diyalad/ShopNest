<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@android:color/white"
    android:clickable="true"
    android:focusable="true"
    app:strokeWidth="1dp"
    app:strokeColor="@color/deep_blue"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/productImage"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder"
            android:contentDescription="Product Image"
            android:background="@color/image_background" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/productName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="T-Shirt Polos"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/black" />

        <!-- Rating and Favorite Container -->

        <!-- Pricing Section -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- Rating -->
            <TextView
                android:id="@+id/ratingText"
                android:layout_width="60dp"
                android:layout_height="31dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="4.5 ⭐"
                android:textColor="@color/gold"
            android:textSize="12sp" />

            <!-- Favorite Icon - Positioned to the right of rating -->
            <ImageView
                android:id="@+id/favoriteIcon"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:clickable="true"
                android:contentDescription="Favorite"
                android:focusable="true"
                android:padding="4dp"
                android:src="@drawable/baseline_favorite_border_24"
                app:tint="@color/red" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <!-- Discounted Price -->
            <TextView
                android:id="@+id/discountedPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1,999"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <!-- Original Price (Strikethrough) -->
            <TextView
                android:id="@+id/originalPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M.R.P: ₹4,999"
                android:textSize="12sp"
                android:textColor="#666666"
                android:paddingTop="2dp" />

            <!-- Discount Percentage -->
            <TextView
                android:id="@+id/discountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="64% off"
                android:textSize="12sp"
                android:textColor="@color/green"
                android:paddingTop="2dp" />

            <!-- Details -->
            <TextView
                android:id="@+id/deliveryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Add to Cart Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addToCartButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add to cart"
            android:textColor="@color/deep_blue"
            android:background="@drawable/button_ripple"
            android:padding="8dp"
            app:cornerRadius="8dp"
            android:layout_marginTop="8dp"
            android:elevation="2dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>